# ===========================================
# QuickLoot.net Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# MongoDB Connection (Required)
# Get free MongoDB Atlas: https://www.mongodb.com/cloud/atlas
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/quickloot?retryWrites=true&w=majority

# Database Name
DB_NAME=quickloot

# Site URL (Your Vercel domain)
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# JWT Secret for Admin Authentication (Required)
# Generate with: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Admin Password Hash - Base64 encoded (Required)
# Generate with: node -e "console.log(Buffer.from(require('bcryptjs').hashSync('your_password', 12)).toString('base64'))"
# Default password: quickloot_strong_password_123!
ADMIN_PASSWORD_HASH_B64=JDJiJDEyJG02WDBXRmp1ZG5MWHBwMXAzV0ZweE9TSm4yL2lxLjlGS0hNT25IdzRIY2V3bTk4MjFVS3Nx

# Admin Session Duration (hours)
ADMIN_SESSION_HOURS=24

# Vercel Cron Secret (Optional but recommended)
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-key

# CORS Origins (comma separated or * for all)
CORS_ORIGINS=*
